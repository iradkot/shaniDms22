<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/glucose_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="14dp"
  android:background="@drawable/glucose_widget_bg">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/glucose_value"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="--"
      android:textSize="38sp"
      android:textStyle="bold"
      android:textColor="@android:color/white" />

    <TextView
      android:id="@+id/glucose_trend"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:text="•"
      android:textSize="22sp"
      android:textStyle="bold"
      android:textColor="#E6FFFFFF" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/glucose_basal"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Basal --U"
      android:textSize="12sp"
      android:textStyle="bold"
      android:maxLines="1"
      android:ellipsize="end"
      android:textColor="#D9FFFFFF" />

    <TextView
      android:id="@+id/glucose_bolus"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Bolus --U"
      android:textSize="12sp"
      android:textStyle="bold"
      android:maxLines="1"
      android:ellipsize="end"
      android:textColor="#D9FFFFFF" />

    <TextView
      android:id="@+id/glucose_tir"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="TIR --%"
      android:textSize="12sp"
      android:textStyle="bold"
      android:maxLines="1"
      android:ellipsize="end"
      android:textColor="#D9FFFFFF" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="2dp"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <TextView
      android:id="@+id/glucose_ratio"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Ratio --%"
      android:textSize="12sp"
      android:maxLines="1"
      android:ellipsize="end"
      android:textColor="#BFFFFFFF" />

    <TextView
      android:id="@+id/glucose_total_insulin"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Total --U"
      android:textSize="12sp"
      android:maxLines="1"
      android:ellipsize="end"
      android:textColor="#BFFFFFFF" />
  </LinearLayout>

  <TextView
    android:id="@+id/glucose_projected"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:text="Next → -- → -- → --"
    android:textSize="15sp"
    android:textStyle="bold"
    android:textColor="#B3FFFFFF" />

  <ImageView
    android:id="@+id/glucose_sparkline"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:layout_marginTop="6dp"
    android:contentDescription="glucose sparkline"
    android:scaleType="fitXY" />

  <TextView
    android:id="@+id/glucose_updated"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:text="No data"
    android:textSize="12sp"
    android:textColor="#80FFFFFF" />

  <Chronometer
    android:id="@+id/glucose_updated_chrono"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:visibility="gone"
    android:textSize="12sp"
    android:textColor="#80FFFFFF"
    android:format="%s ago" />

</LinearLayout>
