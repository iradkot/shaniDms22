<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/glucose_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="8dp"
  android:background="@drawable/glucose_widget_bg">

  <LinearLayout
    android:id="@+id/glucose_widget_header"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="0.9"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingTop="6dp"
    android:paddingEnd="10dp"
    android:paddingBottom="6dp"
    android:background="@drawable/glucose_widget_header_bg">

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
          android:id="@+id/glucose_value"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="--"
          android:textSize="28sp"
          android:textStyle="bold"
          android:textColor="#111827" />

        <TextView
          android:id="@+id/glucose_trend"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="6dp"
          android:text="•"
          android:textSize="22sp"
          android:textStyle="bold"
          android:textColor="#111827" />
      </LinearLayout>

      <TextView
        android:id="@+id/glucose_load"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IOB --U · COB --g"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#CC111827" />

      <TextView
        android:id="@+id/glucose_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No data"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#B3111827" />

      <Chronometer
        android:id="@+id/glucose_updated_chrono"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#B3111827"
        android:format="%s ago" />
    </LinearLayout>

    <TextView
      android:id="@+id/glucose_projected"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:gravity="end|center_vertical"
      android:text="Next\n--  --  --"
      android:textSize="12sp"
      android:textStyle="bold"
      android:maxLines="2"
      android:textColor="#111827" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1.4"
    android:layout_marginTop="6dp"
    android:orientation="vertical">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/glucose_basal"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="3dp"
        android:layout_weight="1"
        android:background="@drawable/glucose_widget_metric_basal_bg"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:padding="5dp"
        android:text="-- U&#10;Basal"
        android:textColor="#F9FAFB"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/glucose_bolus"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="3dp"
        android:layout_weight="1"
        android:background="@drawable/glucose_widget_metric_bolus_bg"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:padding="5dp"
        android:text="-- U&#10;Bolus"
        android:textColor="#111827"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:layout_marginTop="6dp"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/glucose_tir"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="3dp"
        android:layout_weight="1"
        android:background="@drawable/glucose_widget_metric_tir_bg"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:padding="5dp"
        android:text="--%&#10;TIR"
        android:textColor="#111827"
        android:textSize="12sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/glucose_total_insulin"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginStart="3dp"
        android:layout_weight="1"
        android:background="@drawable/glucose_widget_metric_total_bg"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="2"
        android:padding="5dp"
        android:text="-- U&#10;Total"
        android:textColor="#F9FAFB"
        android:textSize="12sp"
        android:textStyle="bold" />
    </LinearLayout>
  </LinearLayout>

  <TextView
    android:id="@+id/glucose_ratio"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp"
    android:gravity="center"
    android:text="Basal/Bolus --%"
    android:textSize="11sp"
    android:textStyle="bold"
    android:textColor="#D9FFFFFF" />

</LinearLayout>
