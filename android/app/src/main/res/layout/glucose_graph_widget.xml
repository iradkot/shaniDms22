<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/glucose_graph_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="8dp"
  android:background="@drawable/glucose_widget_bg">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingTop="6dp"
    android:paddingEnd="10dp"
    android:paddingBottom="6dp"
    android:background="@drawable/glucose_widget_header_bg">

    <TextView
      android:id="@+id/glucose_graph_value"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="--"
      android:textSize="28sp"
      android:textStyle="bold"
      android:textColor="#111827" />

    <TextView
      android:id="@+id/glucose_graph_trend"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginStart="6dp"
      android:text="•"
      android:textSize="22sp"
      android:textStyle="bold"
      android:textColor="#111827" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="12dp"
      android:layout_weight="1"
      android:orientation="vertical"
      android:gravity="end">

      <TextView
        android:id="@+id/glucose_graph_load"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="IOB --U · COB --g"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#CC111827" />

      <TextView
        android:id="@+id/glucose_graph_updated"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:text="No data"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#B3111827" />

      <Chronometer
        android:id="@+id/glucose_graph_updated_chrono"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:visibility="gone"
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="#B3111827"
        android:format="%s ago" />
    </LinearLayout>
  </LinearLayout>

  <ImageView
    android:id="@+id/glucose_graph_sparkline"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:layout_marginTop="8dp"
    android:contentDescription="glucose graph"
    android:scaleType="fitCenter" />

</LinearLayout>
